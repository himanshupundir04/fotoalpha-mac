{
  "name": "fotoalpha",
  "version": "0.1.5",
  "main": "electron/main.js",
  "homepage": "./",
  "private": true,
  "files": [
    "electron/**/*",
    "build/**/*",
    "public/**/*",
    "package.json"
  ],
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^7.0.1",
    "@mui/material": "^7.0.2",
    "@mui/x-charts": "^7.28.0",
    "@reduxjs/toolkit": "^2.6.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^13.5.0",
    "axios": "^1.10.0",
    "blueimp-load-image": "^5.16.0",
    "browser-image-compression": "^2.0.2",
    "chokidar": "^4.0.3",
    "cross-env": "^7.0.3",
    "date-fns": "^4.1.0",
    "electron-store": "^10.1.0",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "formik": "^2.4.6",
    "html-to-image": "^1.11.13",
    "image-hash": "^5.3.2",
    "jspdf": "^3.0.1",
    "jsqr": "^1.4.0",
    "lucide-react": "^0.562.0",
    "mui-datatables": "^4.3.0",
    "react": "^19.1.0",
    "react-big-calendar": "^1.19.2",
    "react-dom": "^19.1.0",
    "react-easy-crop": "^5.5.0",
    "react-infinite-scroll-component": "^6.1.0",
    "react-otp-input": "^3.1.1",
    "react-pageflip": "^2.0.3",
    "react-phone-input-2": "^2.15.1",
    "react-qr-code": "^2.0.15",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.5.3",
    "react-scripts": "5.0.1",
    "react-select": "^4.3.1",
    "react-select-country-list": "^2.2.3",
    "react-slick": "^0.30.3",
    "react-toastify": "^11.0.5",
    "react-webcam": "^7.2.0",
    "recharts": "^3.6.0",
    "sharp": "^0.30.7",
    "slick-carousel": "^1.8.1",
    "sweetalert2": "^11.17.2",
    "systeminformation": "^5.30.6",
    "web-vitals": "^2.1.4",
    "yup": "^1.6.1"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "electron": "^25.9.8",
    "electron-builder": "^26.0.12",
    "electron-rebuild": "^3.2.9",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.17",
    "wait-on": "^8.0.3"
  },
  "scripts": {
    "start": "react-scripts start",
    "electron": "electron electron/main.js",
    "build": "react-scripts build",
    "dev": "concurrently \"npm start\" \"npm run electron:wait\"",
    "electron:wait": "wait-on http://localhost:3000 && npm run electron",
    "clean": "rimraf release-builds",
    "package-win": "npm run build && electron-builder --win",
    "postinstall": "electron-builder install-app-deps",
    "package-mac": "npm run build && electron-builder --mac pkg"
  },
  "build": {
    "appId": "com.fotoalpha.app",
    "productName": "FotoAlpha",
    "directories": {
      "buildResources": "public",
      "output": "release-builds"
    },
    "files": [
      "electron/**/*",
      "build/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "asarUnpack": [
      "**/node_modules/sharp/**",
      "**/node_modules/ffmpeg-static/**",
      "**/node_modules/ffprobe-static/**"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/Camera.ico"
    },
    "mac": {
      "target": [
        "pkg"
      ],
      "icon": "public/Camera.icns",
      "category": "public.app-category.photography",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "identity": "FOTO ALPHA AI SYSTEMS (Q999P3V6FM)",
      "entitlements": "plist/entitlements.mac.plist",
      "entitlementsInherit": "plist/entitlements.mac.plist"
    },
    "pkg": {
      "installLocation": "/Applications"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    }
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}